<?xml version="1.0" encoding="utf-8"?>
<!-- Home-screen widget layout for LangToggle -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Globe + app name -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🌐 LangToggle"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:alpha="0.7" />

    <!-- Current language flag + name -->
    <TextView
        android:id="@+id/widget_language_flag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏠"
        android:textSize="32sp"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/widget_language_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Native"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:layout_marginTop="2dp" />

    <!-- Toggle button -->
    <TextView
        android:id="@+id/widget_toggle_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OFF"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        android:background="@drawable/toggle_bg_off"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:layout_marginTop="6dp" />

</LinearLayout>
